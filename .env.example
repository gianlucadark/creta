# Required locally and on Vercel for DOCX ingest.
GOOGLE_GENERATIVE_AI_API_KEY=

# Local-only optional: add a temporary Vercel Blob read-write token when you
# want to seed/test the private Blob store from your machine.
BLOB_READ_WRITE_TOKEN=

# Vercel sets this when the project is connected to creta-blob via OIDC.
# You normally do not need it in local development.
BLOB_STORE_ID=

# Leave these unset while Creta is intentionally open to anyone with the link.
# CRETA_EDITORS=
# CRETA_AUTH_SECRET=
